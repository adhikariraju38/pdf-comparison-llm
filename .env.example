# PDF Comparison Service Configuration

# Application Settings
APP_NAME=PDF Comparison Service
APP_VERSION=1.0.0
DEBUG=False

# File Upload Settings
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
COMPARISON_DPI=300
MAX_PAGES_PER_JOB=100

# CORS Settings
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000,http://127.0.0.1:3000

# Comparison Settings
SIMILARITY_THRESHOLD=0.85

# LLM Default Settings (OPTIONAL - UI configuration takes precedence)
# These are fallback defaults if UI doesn't provide configuration
DEFAULT_LLM_PROVIDER=openai
DEFAULT_OPENAI_MODEL=gpt-4-turbo-preview
DEFAULT_ANTHROPIC_MODEL=claude-3-sonnet-20240229
DEFAULT_TEMPERATURE=0.1

# Storage and Cleanup
CACHE_RESULTS_HOURS=24
AUTO_CLEANUP=True

# NOTE: API keys should be provided through the UI for security
# Never hardcode API keys in production environments
